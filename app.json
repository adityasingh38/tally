{
  "expo": {
    "name": "Tally",
    "slug": "tally",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "backgroundColor": "#0E0F0C",
    "userInterfaceStyle": "dark",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6d5141af-cb22-4e25-b1db-5a9f83a0c262"
    },
    "android": {
      "package": "com.tally",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0F0C"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.WAKE_LOCK"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "6d5141af-cb22-4e25-b1db-5a9f83a0c262"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0E0F0C"
        }
      ],
      "./plugins/withNativeCapture.js",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "BrokeStreakWidget",
              "label": "Tally — broke streak",
              "description": "Days under budget + today's spend, at a glance.",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "@sentry/react-native"
    ]
  }
}
