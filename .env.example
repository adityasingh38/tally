# Supabase — get from https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# RevenueCat — get from https://app.revenuecat.com -> Project -> API Keys -> Public SDK key (Android)
# Leave empty to disable billing (free tier enforced in prod, unlocked in dev)
REVENUECAT_API_KEY=

# Anthropic — server-side only, for the Edge Function. Never bundled into the app.
# Deploy with: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=
